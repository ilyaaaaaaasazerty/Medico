# ============================================================
# Medico Backend — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/medico?schema=public"

# --- Server ---
PORT=3001
NODE_ENV=development
BACKEND_URL="http://localhost:3001"

# --- JWT (generate a strong random secret >= 32 chars) ---
JWT_SECRET="replace-with-a-secure-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Security ---
BCRYPT_ROUNDS=12

# --- OTP ---
OTP_EXPIRES_MINUTES=10

# --- File Upload ---
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# --- CORS ---
FRONTEND_URL="http://localhost:3000"
MOBILE_URL="exp://localhost:8081"

# --- Email (SMTP) ---
# Works with any SMTP provider: Gmail, Outlook, AWS SES, Mailgun, etc.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Medico <noreply@medico.app>"

# --- SMS (Twilio) ---
# Sign up at https://www.twilio.com — free trial available
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Redis ---
# Required for BullMQ job queues and rate limiting
REDIS_URL="redis://localhost:6379"

# --- AWS S3 (optional — for file uploads) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_BUCKET=""
