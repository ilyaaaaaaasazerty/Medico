// Prisma Schema for Medico Medical Platform
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE USER MODELS
// ============================================

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  phone         String?    @unique
  passwordHash  String
  role          Role
  status        UserStatus @default(PENDING)
  emailVerified Boolean    @default(false)
  phoneVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLoginAt     DateTime?
  expoPushToken   String?

  // Relations
  patient           Patient?
  doctor            Doctor?
  clinicAdmin       ClinicAdmin?
  labAdmin          LabAdmin?
  systemAdmin       SystemAdmin?
  sessions          Session[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  staff             Staff?
  clinicStaff       ClinicStaff?
  payouts           Payout[]
  transportProvider TransportProvider?

  // Financial
  wallet            Wallet?
  transactions      Transaction[]
  receivedTransfers Transaction[] @relation("Recipient")

  // Messaging
  messageThreadParticipants MessageThreadParticipant[]
  sentMessages              Message[]
  ticketReplies             TicketReply[]

  deletedAt DateTime?

  @@index([role])
}

enum Role {
  PATIENT
  DOCTOR
  CLINIC_ADMIN
  LAB_ADMIN
  SYSTEM_ADMIN
  SUPER_ADMIN
  STAFF
  TRANSPORT_PROVIDER
}

enum PaymentMethod {
  CASH
  ONLINE
  WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
}

model OTP {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OTPType
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum OTPType {
  PHONE
  EMAIL
}

// ============================================
// PATIENT MODELS
// ============================================

model Patient {
  id             String     @id @default(uuid())
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         Gender
  avatarUrl      String?
  bloodType      BloodType?
  height         Float?
  weight         Float?
  address        String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  emergencyName  String?
  emergencyPhone String?

  // Phase 13: Digital Identity & Lifestyle
  insuranceProvider     String?
  insurancePolicyNumber String?
  insuranceGroupNumber  String?
  insuranceImageFront   String?
  insuranceImageBack    String?
  primaryCarePhysician  String?
  primaryPharmacy       String?
  smokingStatus         String?
  alcoholStatus         String?
  dietaryHabits         String?
  isDonor               Boolean   @default(false)
  lastDonationAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  allergies         Allergy[]
  conditions        ChronicCondition[]
  medications       Medication[]
  vaccinations      Vaccination[]
  vitalSigns        VitalSign[]
  appointments      Appointment[]
  medicalRecords    MedicalRecord[]
  documents         Document[]
  transactions      Transaction[]
  familyMembers     FamilyMember[]
  reviews           Review[]
  referrals         Referral[]
  labRequests       LabRequest[]
  supportTickets    SupportTicket[]
  vitals            VitalRecording[] // Added as per instruction
  bloodRequests     BloodRequest[]
  donations         BloodDonation[]
  transportRequests TransportRequest[]

  deletedAt DateTime?

  @@index([userId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
}

model FamilyMember {
  id           String       @id @default(uuid())
  patientId    String
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  dateOfBirth  DateTime
  gender       Gender
  relationship Relationship
  bloodType    BloodType?
  allergies    Json?
  conditions   Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  appointments   Appointment[]
  medicalRecords MedicalRecord[]
}

enum Relationship {
  CHILD
  SPOUSE
  PARENT
  SIBLING
  OTHER
}

model Allergy {
  id        String   @id @default(uuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  severity  Severity
  reaction  String?
  createdAt DateTime @default(now())
}


model ChronicCondition {
  id          String    @id @default(uuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name        String
  diagnosedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
}

model Medication {
  id        String               @id @default(uuid())
  patientId String
  patient   Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  dosage    String
  frequency String
  startDate DateTime
  endDate   DateTime?
  reminders MedicationReminder[]
  createdAt DateTime             @default(now())
}

model MedicationReminder {
  id           String     @id @default(uuid())
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  time         String
  enabled      Boolean    @default(true)
}

model Vaccination {
  id          String    @id @default(uuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name        String
  dateGiven   DateTime
  provider    String?
  nextDueDate DateTime?
  documentId  String?
  createdAt   DateTime  @default(now())
}

model VitalSign {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type       String
  value      Float
  unit       String
  recordedAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
}

enum VitalType {
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE_DIASTOLIC
  HEART_RATE
  TEMPERATURE
  WEIGHT
  HEIGHT
  BLOOD_GLUCOSE
  OXYGEN_SATURATION
}

enum Severity {
  MILD
  MODERATE
  SEVERE
}

// ============================================
// DOCTOR MODELS
// ============================================

model Doctor {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  title              String?
  avatarUrl          String?
  bio                String?
  licenseNumber      String             @unique
  licenseExpiry      DateTime
  yearsExperience    Int?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String?
  consultationFee    Int?
  teleconsultEnabled Boolean            @default(false)
  averageRating      Float?
  totalReviews       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  specialties            DoctorSpecialty[]
  education              Education[]
  documents              DoctorDocument[]
  clinicAffiliations     ClinicDoctor[]
  availabilities         Availability[]
  availabilityExceptions AvailabilityException[]
  appointments           Appointment[]
  prescriptions          Prescription[]
  reviews                Review[]
  earnings               Earning[]
  payouts                Payout[]
  referralsSent          Referral[]              @relation("ReferringDoctor")
  referralsReceived      Referral[]              @relation("ReferredDoctor")
  prescriptionTemplates  PrescriptionTemplate[]
  patientNotes           PatientNote[]
  documentTemplate       DocumentTemplate?       @relation("DoctorDocumentTemplate")

  // Financial (Algerian Intermediary Model)
  bankRIB      String?
  payoutStatus VerificationStatus @default(PENDING)

  emergencyMode Boolean @default(false)

  deletedAt DateTime?

  @@index([userId])
  @@index([verificationStatus])
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

model Specialty {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  iconUrl     String?
  isActive    Boolean           @default(true)
  doctors     DoctorSpecialty[]
  services    Service[]
}

model DoctorSpecialty {
  id          String    @id @default(uuid())
  doctorId    String
  doctor      Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialtyId String
  specialty   Specialty @relation(fields: [specialtyId], references: [id])
  isPrimary   Boolean   @default(false)

  @@unique([doctorId, specialtyId])
}

model Education {
  id          String   @id @default(uuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  degree      String
  institution String
  year        Int
  createdAt   DateTime @default(now())
}

model DoctorDocument {
  id          String        @id @default(uuid())
  doctorId    String
  doctor      Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  type        DoctorDocType
  fileUrl     String
  fileName    String
  status      DocStatus     @default(PENDING)
  reviewNotes String?
  uploadedAt  DateTime      @default(now())
}

enum DoctorDocType {
  LICENSE
  DEGREE
  CERTIFICATION
  ID_PROOF
  OTHER
}

enum DocStatus {
  PENDING
  APPROVED
  REJECTED
}

model Availability {
  id           String   @id @default(uuid())
  doctorId     String
  doctor       Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicId     String?
  clinic       Clinic?  @relation(fields: [clinicId], references: [id])
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([doctorId, clinicId, dayOfWeek])
}

model AvailabilityException {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date      DateTime
  isBlocked Boolean  @default(true)
  reason    String?
  startTime String?
  endTime   String?
  createdAt DateTime @default(now())
}

model PrescriptionTemplate {
  id           String   @id @default(uuid())
  doctorId     String
  doctor       Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  name         String
  diagnosis    String?
  medications  Json
  instructions String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PatientNote {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patientId String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// CLINIC MODELS
// ============================================

model Clinic {
  id                 String             @id @default(uuid())
  name               String
  description        String?
  logoUrl            String?
  email              String
  phone              String
  website            String?
  address            String
  city               String
  state              String
  country            String
  postalCode         String
  latitude           Float?
  longitude          Float?
  registrationNumber String?
  taxId              String?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  isActive           Boolean            @default(true)
  is24Hours          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  // - [x] Phase 28: Emergency & Schedule Control
  //   - [x] Implement "Emergency Mode" in `Doctor` and `Clinic` models
  //   - [x] Create backend services and routes for emergency toggling
  //   - [x] Implement schedule shifting (setback) backend logic
  //   - [x] Update Clinic and Doctor dashboards with Emergency/Setback UI
  //   - [x] Add emergency alerts to Reception Display TV overlay
  //   - [x] Enhance clinical order creation (Labs, Imaging, Procedures) in consultation flow
  //   - [x] Verify implementation and document changes
  parentClinicId     String?
  parentClinic       Clinic?            @relation("ClinicBranches", fields: [parentClinicId], references: [id])
  branches           Clinic[]           @relation("ClinicBranches")

  // Relations
  admins           ClinicAdmin[]
  doctors          ClinicDoctor[]
  staff            ClinicStaff[]
  services         ClinicService[]
  rooms            Room[]
  availabilities   Availability[]
  appointments     Appointment[]
  workingHours     WorkingHours[]
  documents        ClinicDocument[]
  payouts          Payout[]
  serviceTypes     ClinicServiceType[]
  waitlist         WaitlistEntry[]
  documentTemplate DocumentTemplate?

  // Financial
  bankRIB String?

  emergencyMode Boolean @default(false)
}

model ClinicAdmin {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicId  String
  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  role      ClinicRole
  createdAt DateTime   @default(now())
}

model ClinicDoctor {
  id       String            @id @default(uuid())
  clinicId String
  clinic   Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctorId String
  doctor   Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status   AffiliationStatus @default(ACTIVE)
  joinedAt DateTime          @default(now())
  leftAt   DateTime?

  @@unique([clinicId, doctorId])
}

model ClinicStaff {
  id        String    @id @default(uuid())
  userId    String?   @unique
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinicId  String
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      StaffRole
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
}

enum ClinicRole {
  OWNER
  MANAGER
  RECEPTIONIST
}

enum StaffRole {
  NURSE
  RECEPTIONIST
  TECHNICIAN
  ADMINISTRATIVE
  OTHER
}

enum AffiliationStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

model Room {
  id              String           @id @default(uuid())
  clinicId        String
  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name            String
  type            RoomType
  isActive        Boolean          @default(true)
  appointments    Appointment[]
  roomAssignments RoomAssignment[]
}

enum RoomType {
  CONSULTATION
  EXAMINATION
  PROCEDURE
  WAITING
  OTHER
}

model WorkingHours {
  id        String  @id @default(uuid())
  clinicId  String
  clinic    Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean @default(false)

  @@unique([clinicId, dayOfWeek])
}

model ClinicDocument {
  id         String        @id @default(uuid())
  clinicId   String
  clinic     Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  type       ClinicDocType
  fileUrl    String
  fileName   String
  status     DocStatus     @default(PENDING)
  uploadedAt DateTime      @default(now())
}

enum ClinicDocType {
  LICENSE
  REGISTRATION
  TAX_CERTIFICATE
  INSURANCE
  OTHER
}

// ============================================
// LAB / RADIOLOGY MODELS
// ============================================

model LabCenter {
  id                 String             @id @default(uuid())
  name               String
  type               LabType
  description        String?
  logoUrl            String?
  email              String
  phone              String
  address            String
  city               String
  state              String
  country            String
  latitude           Float?
  longitude          Float?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  isActive           Boolean            @default(true)
  homeCollection     Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  admins           LabAdmin[]
  technicians      LabTechnician[]
  tests            LabTest[]
  requests         LabRequest[]
  workingHours     LabWorkingHours[]
  equipment        LabEquipment[]
  slots            LabSlot[]
  payouts          Payout[]
  documentTemplate DocumentTemplate?

  // Financial
  bankRIB String?
}

enum LabType {
  LABORATORY
  RADIOLOGY
  BOTH
}

model LabAdmin {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  labCenterId String
  labCenter   LabCenter @relation(fields: [labCenterId], references: [id], onDelete: Cascade)
  role        LabRole
  createdAt   DateTime  @default(now())
}

model LabTechnician {
  id          String                 @id @default(uuid())
  labCenterId String
  labCenter   LabCenter              @relation(fields: [labCenterId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  email       String?
  phone       String?
  specialty   String?
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  requests    LabTechnicianRequest[]
  assignedRequests LabRequest[]      @relation("PrimaryTechnician")
}

model LabTechnicianRequest {
  id           String        @id @default(uuid())
  technicianId String
  technician   LabTechnician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  requestId    String
  request      LabRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([technicianId, requestId])
}

model LabEquipment {
  id              String    @id @default(uuid())
  labCenterId     String
  labCenter       LabCenter @relation(fields: [labCenterId], references: [id], onDelete: Cascade)
  name            String
  type            String
  isOperational   Boolean   @default(true)
  nextMaintenance DateTime?
}

enum LabRole {
  OWNER
  MANAGER
  STAFF
}

model LabTest {
  id              String           @id @default(uuid())
  labCenterId     String
  labCenter       LabCenter        @relation(fields: [labCenterId], references: [id], onDelete: Cascade)
  name            String
  category        TestCategory
  description     String?
  preparation     String?
  turnaroundHours Int?
  price           Int              @default(0)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  requestItems    LabRequestItem[]
}

enum TestCategory {
  BLOOD
  URINE
  IMAGING
  GENETIC
  PATHOLOGY
  PROCEDURE
  OTHER
}

model LabSlot {
  id          String    @id @default(uuid())
  labCenterId String
  labCenter   LabCenter @relation(fields: [labCenterId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String
  endTime     String
  capacity    Int
  booked      Int       @default(0)
  isBlocked   Boolean   @default(false)
}

model LabWorkingHours {
  id          String    @id @default(uuid())
  labCenterId String
  labCenter   LabCenter @relation(fields: [labCenterId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  openTime    String
  closeTime   String
  isClosed    Boolean   @default(false)

  @@unique([labCenterId, dayOfWeek])
}

model LabRequest {
  id              String                 @id @default(uuid())
  labCenterId     String
  labCenter       LabCenter              @relation(fields: [labCenterId], references: [id])
  patientId       String
  patient         Patient                @relation(fields: [patientId], references: [id])
  referralId      String?
  referral        Referral?              @relation(fields: [referralId], references: [id])
  status          LabRequestStatus       @default(PENDING)
  scheduledDate   DateTime
  scheduledTime   String
  prescriptionUrl String?
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  items           LabRequestItem[]
  results         LabResult[]
  transaction     Transaction?
  technicianId    String?
  technician      LabTechnician?         @relation("PrimaryTechnician", fields: [technicianId], references: [id])
  technicians     LabTechnicianRequest[]
}

model LabRequestItem {
  id        String     @id @default(uuid())
  requestId String
  request   LabRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  testId    String
  test      LabTest    @relation(fields: [testId], references: [id])
  status    ItemStatus @default(PENDING)
}

model LabResult {
  id         String     @id @default(uuid())
  requestId  String
  request    LabRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fileUrl    String
  fileName   String
  notes      String?
  uploadedAt DateTime   @default(now())
  uploadedBy String
}

enum LabRequestStatus {
  PENDING
  CONFIRMED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ============================================
// SERVICE & APPOINTMENT MODELS
// ============================================

model Service {
  id             String          @id @default(uuid())
  name           String
  description    String?
  duration       Int
  price          Int             @default(0)
  specialtyId    String?
  specialty      Specialty?      @relation(fields: [specialtyId], references: [id])
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  clinicServices ClinicService[]
  appointments   Appointment[]
}

model ClinicService {
  id        String  @id @default(uuid())
  clinicId  String
  clinic    Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
  price     Int?
  isActive  Boolean @default(true)

  @@unique([clinicId, serviceId])
}

model Appointment {
  id                 String            @id @default(uuid())
  patientId          String
  patient            Patient           @relation(fields: [patientId], references: [id])
  familyMemberId     String?
  familyMember       FamilyMember?     @relation(fields: [familyMemberId], references: [id])
  doctorId           String
  doctor             Doctor            @relation(fields: [doctorId], references: [id])
  clinicId           String?
  clinic             Clinic?           @relation(fields: [clinicId], references: [id])
  serviceId          String
  service            Service           @relation(fields: [serviceId], references: [id])
  roomId             String?
  room               Room?             @relation(fields: [roomId], references: [id])
  waitlistEntry      WaitlistEntry?
  roomAssignments    RoomAssignment[]
  scheduledDate      DateTime
  scheduledTime      String
  duration           Int
  status             AppointmentStatus @default(PENDING)
  checkInTime        DateTime?
  startTime          DateTime?
  endTime            DateTime?
  type               AppointmentType   @default(IN_PERSON)
  videoCallUrl       String?
  reason             String?
  patientNotes       String?
  cancellationReason String?
  rescheduleCount    Int               @default(0)
  price              Int
  paymentMethod      PaymentMethod     @default(CASH)
  paymentStatus      PaymentStatus     @default(PENDING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  prescription  Prescription?
  medicalRecord MedicalRecord?
  transactions  Transaction[]
  review        Review?
  reminders     Reminder[]
  attachments   Document[]

  vitals         VitalRecording[]
  clinicalOrders ClinicalOrder[]

  deletedAt DateTime?

  @@index([patientId])
  @@index([doctorId])
  @@index([clinicId])
  @@index([status])
  @@index([scheduledDate])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CALLED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
  EMERGENCY
}

enum AppointmentType {
  IN_PERSON
  VIDEO_CALL
  HOME_VISIT
}

// ============================================
// MEDICAL RECORDS MODELS
// ============================================

model MedicalRecord {
  id             String        @id @default(uuid())
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id])
  familyMemberId String?
  familyMember   FamilyMember? @relation(fields: [familyMemberId], references: [id])
  appointmentId  String?       @unique
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  doctorId       String?
  visitDate      DateTime
  chiefComplaint String?
  symptoms       String?
  diagnosis      String?
  notes          String?
  bloodPressure  String?
  heartRate      Int?
  temperature    Float?
  weight         Float?
  followUpDate   DateTime?
  followUpNotes  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  deletedAt DateTime?

  attachments    Document[]
  prescription   Prescription?
  clinicalOrders ClinicalOrder[]

  @@index([patientId])
  @@index([doctorId])
}

model AiTrainingData {
  id           String   @id @default(uuid())
  specialty    String?
  ageGroup     String?
  gender       Gender?
  content      Json // Anonymized SOAP data
  anonymizedAt DateTime @default(now())
  metadata     Json? // Optional non-PII metadata
}

model Document {
  id            String         @id @default(uuid())
  patientId     String
  patient       Patient        @relation(fields: [patientId], references: [id])
  recordId      String?
  record        MedicalRecord? @relation(fields: [recordId], references: [id])
  appointmentId String?
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  type          DocumentType
  name          String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  uploadedBy    String
  uploadedAt    DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  isShared      Boolean        @default(false)
  shareToken    String?
  shareExpiry   DateTime?
}

enum DocumentType {
  LAB_RESULT
  PRESCRIPTION
  IMAGING
  REPORT
  MEDICAL_REPORT
  INSURANCE
  ID_DOCUMENT
  ID_CARD
  OTHER
}

model Prescription {
  id                 String             @id @default(uuid())
  appointmentId      String?            @unique
  appointment        Appointment?       @relation(fields: [appointmentId], references: [id])
  recordId           String?            @unique
  record             MedicalRecord?     @relation(fields: [recordId], references: [id])
  doctorId           String
  doctor             Doctor             @relation(fields: [doctorId], references: [id])
  patientId          String
  diagnosis          String?
  instructions       String?
  pdfUrl             String?
  temporarySignature String?
  validUntil         DateTime?
  createdAt          DateTime           @default(now())
  items              PrescriptionItem[]
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medication     String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  quantity       Int?
}

model ClinicalOrder {
  id            String            @id @default(uuid())
  appointmentId String
  appointment   Appointment       @relation(fields: [appointmentId], references: [id])
  recordId      String?
  record        MedicalRecord?    @relation(fields: [recordId], references: [id])
  type          ClinicalOrderType
  status        OrderStatus       @default(PENDING)
  description   String?
  metadata      Json? // Flexible storage for order details
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([appointmentId])
  @@index([type])
}

enum ClinicalOrderType {
  LAB
  IMAGING
  PROCEDURE
  REFERRAL
}

enum OrderStatus {
  PENDING
  ORDERED
  COMPLETED
  CANCELLED
}

// ============================================
// COMMUNICATION MODELS
// ============================================

model MessageThread {
  id            String    @id @default(uuid())
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  // Relations
  participants MessageThreadParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
}

model MessageThreadParticipant {
  id       String        @id @default(uuid())
  threadId String
  thread   MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastRead DateTime?
  joinedAt DateTime      @default(now())

  @@unique([threadId, userId])
}

model Message {
  id        String        @id @default(uuid())
  threadId  String
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation(fields: [senderId], references: [id])
  content   String?
  type      MessageType   @default(TEXT)
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([threadId, createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VOICE
  APPOINTMENT
  SYSTEM
}

// ============================================
// SUPPORT TICKETS
// ============================================

model SupportTicket {
  id         String       @id @default(uuid())
  patientId  String
  patient    Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  subject    String
  content    String
  status     TicketStatus @default(OPEN)
  priority   Priority     @default(NORMAL)
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  replies    TicketReply[]
}

model TicketReply {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  content   String
  isStaff   Boolean       @default(false)
  createdAt DateTime      @default(now())
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  NORMAL
  URGENT
}

// ============================================
// FINANCIAL MODELS
// ============================================

model Wallet {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance           Int      @default(0)
  pendingBalance    Int      @default(0)
  redeemableBalance Int      @default(0)
  currency          String   @default("DZD")
  updatedAt         DateTime @updatedAt
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Int?
  fee           Int               @default(0)
  currency      String?           @default("DZD")
  status        TransactionStatus @default(PENDING)
  referenceId   String?           @unique
  providerId    String?           @unique // Chargily Invoice ID
  description   String?
  paymentMethod PaymentMethod?

  // Relations
  patientId     String?
  patient       Patient?     @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  labRequestId  String?      @unique
  labRequest    LabRequest?  @relation(fields: [labRequestId], references: [id])

  recipientId String?
  recipient   User?   @relation("Recipient", fields: [recipientId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model VerificationRequest {
  id         String             @id @default(uuid())
  type       VerificationType
  targetId   String
  status     VerificationStatus @default(PENDING)
  notes      String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime           @default(now())
}

enum VerificationType {
  DOCTOR
  CLINIC
  LAB
}

model FeatureFlag {
  key     String  @id
  enabled Boolean @default(false)
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  REFUND
  TRANSFER
  EARNING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  COMPLETED
  REFUNDED
}

model Earning {
  id         String   @id @default(uuid())
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])
  amount     Int
  currency   String   @default("DZD")
  sourceType String // APPOINTMENT
  sourceId   String
  createdAt  DateTime @default(now())
}

model Payout {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  doctorId    String?
  doctor      Doctor?      @relation(fields: [doctorId], references: [id])
  clinicId    String?
  clinic      Clinic?      @relation(fields: [clinicId], references: [id])
  labCenterId String?
  labCenter   LabCenter?   @relation(fields: [labCenterId], references: [id])
  amount      Int
  currency    String       @default("DZD")
  bankRIB     String
  status      PayoutStatus @default(PENDING)
  referenceId String?
  requestedAt DateTime     @default(now())
  processedAt DateTime?
  createdAt   DateTime     @default(now())
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ============================================
// REVIEWS & RATINGS
// ============================================

model Review {
  id            String       @id @default(uuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor       @relation(fields: [doctorId], references: [id])
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime     @default(now())
}

// ============================================
// SYSTEM MODELS
// ============================================

model SystemAdmin {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Staff {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  position   String
  department String
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

// ============================================
// REFERRALS
// ============================================

model Referral {
  id                String         @id @default(uuid())
  patientId         String
  patient           Patient        @relation(fields: [patientId], references: [id])
  referringDoctorId String
  referringDoctor   Doctor         @relation("ReferringDoctor", fields: [referringDoctorId], references: [id])
  referredDoctorId  String?
  referredDoctor    Doctor?        @relation("ReferredDoctor", fields: [referredDoctorId], references: [id])
  specialtyNeeded   String?
  reason            String
  status            ReferralStatus @default(PENDING)
  createdAt         DateTime       @default(now())

  labRequests LabRequest[]
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

// ============================================
// NOTIFICATIONS & REMINDERS
// ============================================

model Reminder {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  type          String // EMAIL, SMS, PUSH
  scheduledAt   DateTime
  sentAt        DateTime?
  status        String      @default("PENDING")
}

enum ServiceCategory {
  PRIMARY_CARE
  DIAGNOSTIC
  SPECIALIST
  THERAPEUTIC
  EMERGENCY
}

// ============================================
// CLINIC OPERATIONS
// ============================================

model ClinicServiceType {
  id       String          @id @default(uuid())
  clinicId String
  clinic   Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name     String
  category ServiceCategory @default(PRIMARY_CARE)
  price    Int
  isActive Boolean         @default(true)
}

model RoomAssignment {
  id            String      @id @default(uuid())
  roomId        String
  room          Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  startTime     DateTime    @default(now())
  releasedAt    DateTime?
}

model WaitlistEntry {
  id            String         @id @default(uuid())
  clinicId      String
  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String         @unique
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  queuePosition Int
  status        WaitlistStatus @default(WAITING)
  calledAt      DateTime?
  checkedInAt   DateTime       @default(now())
  joinedAt      DateTime       @default(now())
}

enum WaitlistStatus {
  WAITING
  CALLED
  WITH_NURSE
  WITH_DOCTOR
  COMPLETED
  NO_SHOW
}

// ============================================
// ADDITIONAL CLINICAL MODELS
// ============================================

model VitalRecording {
  id            String       @id @default(uuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  type          VitalType
  value         Float
  unit          String
  recordedAt    DateTime     @default(now())
}

// ============================================
// DOCUMENT TEMPLATES (Phase 13)
// ============================================

model DocumentTemplate {
  id          String     @id @default(uuid())
  doctorId    String?    @unique
  doctor      Doctor?    @relation("DoctorDocumentTemplate", fields: [doctorId], references: [id], onDelete: Cascade)
  clinicId    String?    @unique
  clinic      Clinic?    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  labCenterId String?    @unique
  labCenter   LabCenter? @relation(fields: [labCenterId], references: [id], onDelete: Cascade)

  logoUrl        String?
  headerTitle    String
  headerSubtitle String?
  headerAddress  String?
  headerPhone    String?
  headerColor    String  @default("#0A84FF")
  footerText     String?
  signatureUrl   String?

  primaryColor   String @default("#0A84FF")
  secondaryColor String @default("#444444")

  showRxSymbol  Boolean @default(true)
  showDiagnosis Boolean @default(true)
  showPatientId Boolean @default(true)
  showQrCode    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// TRANSPORT MODELS (Phase 13 - Logistics)
// ============================================



model TransportProvider {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String
  type               TransportType      @default(AMBULANCE)
  status             TransportProviderStatus @default(AVAILABLE)
  licenseNumber      String             @unique
  verificationStatus VerificationStatus @default(PENDING)
  isIndividual       Boolean            @default(true)
  walletBalance      Int                @default(0) // Cache for quick access
  vehicles           Vehicle[]
  requests           TransportRequest[]
  workingHours       TransportWorkingHours[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model TransportWorkingHours {
  id                  String            @id @default(uuid())
  transportProviderId String
  transportProvider   TransportProvider @relation(fields: [transportProviderId], references: [id], onDelete: Cascade)
  dayOfWeek           Int
  openTime            String
  closeTime           String
  isClosed            Boolean           @default(false)

  @@unique([transportProviderId, dayOfWeek])
}

enum TransportProviderStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

model Vehicle {
  id           String            @id @default(uuid())
  providerId   String
  provider     TransportProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  type         VehicleType
  licensePlate String            @unique
  isAvailable  Boolean           @default(true)
  currentLat   Float?
  currentLng   Float?
}

enum VehicleType {
  AMBULANCE
  NON_EMERGENCY
  WHEELCHAIR_ACCESSIBLE
}

model TransportRequest {
  id                  String             @id @default(uuid())
  patientId           String
  patient             Patient            @relation(fields: [patientId], references: [id])
  providerId          String?
  transportProviderId String?
  provider            TransportProvider? @relation(fields: [providerId], references: [id])
  pickupAddress       String
  pickupLat           Float?
  pickupLng           Float?
  destinationAddress  String?
  destinationLat      Float?
  destinationLng      Float?
  scheduledAt         DateTime?
  status              TransportReqStatus @default(PENDING)
  costs               Int?
  acceptedAt          DateTime?
  arrivedAt           DateTime?
  pickedUpAt          DateTime?
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
}

enum TransportType {
  AMBULANCE
  EMERGENCY
  NON_EMERGENCY
  WHEELCHAIR_ACCESSIBLE
}

enum TransportReqStatus {
  PENDING
  ACCEPTED
  ARRIVED_PICKUP
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

// ============================================
// BLOOD BANK MODELS (Phase 13 - Health Loop)
// ============================================

model BloodRequest {
  id          String             @id @default(uuid())
  patientId   String
  patient     Patient            @relation(fields: [patientId], references: [id])
  bloodType   BloodType
  unitsRequired Int
  urgency     UrgencyLevel       @default(NORMAL)
  reason      String?
  location    String?
  latitude    Float?
  longitude   Float?
  status      BloodRequestStatus @default(OPEN)
  createdAt   DateTime           @default(now())
  responses   BloodDonation[]
}

enum UrgencyLevel {
  NORMAL
  HIGH
  EMERGENCY
}

enum BloodRequestStatus {
  OPEN
  FULFILLED
  CANCELLED
}

model BloodDonation {
  id        String                 @id @default(uuid())
  donatedAt DateTime?
  donorId   String
  donor     Patient                @relation(fields: [donorId], references: [id])
  requestId String?
  request   BloodRequest?          @relation(fields: [requestId], references: [id])
  notes     String?
  status    DonationResponseStatus @default(INTERESTED)
  createdAt DateTime               @default(now())
}

enum DonationResponseStatus {
  INTERESTED
  SCREENING
  COMPLETED
  REJECTED
}
