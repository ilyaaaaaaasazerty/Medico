{
    "expo": {
        "name": "Medico",
        "slug": "medico",
        "version": "1.0.0",
        "sdkVersion": "54.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "scheme": "medico",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0A84FF"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.medico.app"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0A84FF"
            },
            "package": "com.medico.app"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-secure-store",
            [
                "expo-camera",
                {
                    "cameraPermission": "Allow Medico to access your camera for document scanning."
                }
            ],
            [
                "expo-image-picker",
                {
                    "photosPermission": "Allow Medico to access your photos for profile and document uploads."
                }
            ],
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification-icon.png",
                    "color": "#0A84FF"
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}